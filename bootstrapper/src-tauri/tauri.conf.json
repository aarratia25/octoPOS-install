{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OctoPOS Setup",
  "version": "0.0.0",
  "identifier": "com.nonlyweb.octopos-bootstrapper",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OctoPOS Setup",
        "width": 720,
        "height": 640,
        "minWidth": 640,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "languages": ["Spanish"]
      }
    },
    "icon": ["icons/icon.ico"],
    "resources": ["embedded/*"]
  }
}
