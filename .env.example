MONGO_USER=octopos
MONGO_PASSWORD=__GENERATED__
MONGO_DB=octopos
MONGO_PORT=27017
MONGO_CONTAINER=octopos-mongodb

API_PORT=3000
JWT_SECRET=__GENERATED__
JWT_EXPIRATION=604800

CORS_ORIGINS=http://localhost,http://localhost:1430,http://localhost:1420,tauri://localhost,https://tauri.localhost,http://tauri.localhost

GITHUB_REPO=aarratia25/octoPOS-admin
OCTOPOS_API_IMAGE=ghcr.io/aarratia25/octopos-admin-api
OCTOPOS_API_VERSION=latest
UPDATES_CRON_ENABLED=true

BACKUP_LOCAL_PATH=/app/backups
BACKUP_RETENTION_DAYS=30
BACKUP_CRON_ENABLED=true

PLATFORM_URL=https://platform.octo-pos.net
PLATFORM_API_KEY=__REQUIRED__
BRANCH_SLUG=__REQUIRED__
